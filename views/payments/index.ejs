<h2 class="text-3xl font-bold mb-6 text-gray-800 tracking-tight">Recent Payment Logs</h2>

<div class="bg-white shadow-xl rounded-2xl overflow-hidden border border-gray-100">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100 uppercase tracking-widest text-xs font-bold text-gray-500">
                    <th class="py-4 px-6 border-b border-gray-200">Phone</th>
                    <th class="py-4 px-6 border-b border-gray-200">Amount</th>
                    <th class="py-4 px-6 border-b border-gray-200">Transaction ID</th>
                    <th class="py-4 px-6 border-b border-gray-200">Status</th>
                    <th class="py-4 px-6 border-b border-gray-200">Verified At</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                <% payments.forEach(payment => { %>
                <tr class="hover:bg-gray-50 transition duration-150 ease-in-out">
                    <td class="py-4 px-6 text-gray-700 font-medium"><%= payment.user_phone %></td>
                    <td class="py-4 px-6 text-green-600 font-bold">₹<%= payment.amount %></td>
                    <td class="py-4 px-6 text-gray-500 font-mono text-xs"><%= payment.transaction_id %></td>
                    <td class="py-4 px-6">
                        <span class="px-3 py-1 bg-green-100 text-green-800 text-xs font-bold rounded-full uppercase tracking-tighter">Verified</span>
                    </td>
                    <td class="py-4 px-6 text-gray-500 text-sm italic">
                        <%= new Date(payment.verified_at).toLocaleString('en-IN') %>
                    </td>
                </tr>
                <% }) %>
                <% if(payments.length === 0) { %>
                <tr>
                    <td colspan="5" class="py-12 px-6 text-center text-gray-400">
                        <i class="fas fa-search-dollar text-4xl mb-3 block"></i>
                        No verified payments found yet.
                    </td>
                </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
