<div class="flex items-center justify-between mb-6">
    <h2 class="text-3xl font-bold text-gray-800">
        <i class="fas <%= locals.product ? 'fa-edit' : 'fa-plus-circle' %> mr-2 text-blue-600"></i>
        <%= locals.product ? 'Edit' : 'Add New' %> Product
    </h2>
    <a href="/admin/products" class="text-gray-500 hover:text-gray-700 flex items-center gap-1 transition">
        <i class="fas fa-arrow-left"></i> Back to Products
    </a>
</div>

<% if (locals.error) { %>
<div class="bg-red-100 border-l-4 border-red-500 text-red-700 px-4 py-3 rounded mb-6" role="alert">
    <p><i class="fas fa-exclamation-circle mr-2"></i><%= error %></p>
</div>
<% } %>

<div class="bg-white shadow-xl rounded-2xl overflow-hidden border border-gray-100 p-8 max-w-4xl mx-auto">
    <form action="<%= locals.product ? '/admin/products/update/' + product.id : '/admin/products/create' %>" method="POST">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <!-- Product Code -->
            <div>
                <label class="block text-gray-700 text-sm font-bold mb-2 uppercase tracking-wide" for="product_code">
                    Product Code <span class="text-red-500">*</span>
                </label>
                <input class="border rounded-lg w-full py-3 px-4 text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition"
                    id="product_code" name="product_code" type="text"
                    value="<%= locals.product ? product.product_code : '' %>"
                    placeholder="e.g. P106" required>
            </div>

            <!-- Title -->
            <div>
                <label class="block text-gray-700 text-sm font-bold mb-2 uppercase tracking-wide" for="title">
                    Product Title <span class="text-red-500">*</span>
                </label>
                <input class="border rounded-lg w-full py-3 px-4 text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition"
                    id="title" name="title" type="text"
                    value="<%= locals.product ? product.title : '' %>"
                    placeholder="e.g. Premium Course" required>
            </div>

            <!-- Price -->
            <div>
                <label class="block text-gray-700 text-sm font-bold mb-2 uppercase tracking-wide" for="price">
                    Price (₹) <span class="text-red-500">*</span>
                </label>
                <input class="border rounded-lg w-full py-3 px-4 text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition"
                    id="price" name="price" type="number" step="0.01" min="0"
                    value="<%= locals.product ? product.price : '' %>"
                    placeholder="e.g. 999" required>
            </div>

            <!-- Delivery Link -->
            <div>
                <label class="block text-gray-700 text-sm font-bold mb-2 uppercase tracking-wide" for="delivery_link">
                    Delivery Link <span class="text-gray-400 font-normal text-xs">(optional)</span>
                </label>
                <input class="border rounded-lg w-full py-3 px-4 text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition"
                    id="delivery_link" name="delivery_link" type="text"
                    value="<%= locals.product ? (product.delivery_link || '') : '' %>"
                    placeholder="https://panel.example.com/...">
            </div>
        </div>

        <!-- Description -->
        <div class="mt-6">
            <label class="block text-gray-700 text-sm font-bold mb-2 uppercase tracking-wide" for="description">
                Description <span class="text-red-500">*</span>
            </label>
            <textarea class="border rounded-lg w-full py-3 px-4 text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition"
                id="description" name="description" rows="4"
                placeholder="Describe the product..." required><%= locals.product ? product.description : '' %></textarea>
        </div>

        <!-- Keywords -->
        <div class="mt-6">
            <label class="block text-gray-700 text-sm font-bold mb-2 uppercase tracking-wide" for="keywords">
                Keywords <span class="text-gray-400 font-normal text-xs">(optional – used for WhatsApp search)</span>
            </label>
            <input class="border rounded-lg w-full py-3 px-4 text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition"
                id="keywords" name="keywords" type="text"
                value="<%= locals.product ? (product.keywords || '') : '' %>"
                placeholder="e.g. course, premium, bundle">
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-4 mt-8">
            <button class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-lg shadow-md hover:shadow-xl transition transform hover:-translate-y-0.5" type="submit">
                <i class="fas fa-save mr-2"></i><%= locals.product ? 'Update Product' : 'Save Product' %>
            </button>
            <a href="/admin/products" class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-3 px-6 rounded-lg transition">
                Cancel
            </a>
        </div>
    </form>
</div>
